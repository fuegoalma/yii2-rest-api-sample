# Application
BASE_URL=http://localhost:8084
DEFAULT_PASSWORD=123456

# Database  
DB_HOST=db
DB_NAME=test
DB_USER=root
DB_PASSWORD=root

# Database for testing
TEST_DB_NAME=test_test

# Secret key for cookie validation (any random 32-char string)
COOKIE_VALIDATION_KEY=change-me-to-a-random-32-char-string

# JWT authorization (any random string, e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-random-jwt-secret
JWT_TTL=3600

# Login rate limiting (brute-force protection): allowed attempts per IP within the window (seconds)
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=60
