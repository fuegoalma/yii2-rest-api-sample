# phpstorm project files
.idea

# visual studio code project files
.vscode

# netbeans project files
nbproject

# zend studio for eclipse project files
.buildpath
.project
.settings

# windows thumbnail cache
Thumbs.db

# composer vendor dir
/vendor

# composer itself is not needed
composer.phar

# Mac DS_Store Files
.DS_Store

# phpunit itself is not needed
phpunit.phar
# local phpunit config
/phpunit.xml

tests/_output/*
tests/_support/_generated

#vagrant folder
/.vagrant

#env
.env

# third-party AI-agent skills installed locally (caveman, etc.) — not project code.
# The installer scatters the same files across four locations; ignore all of
# them but leave .claude/ itself un-ignored in case legitimate project-level
# Claude Code config (settings.json, commands/) is added there later.
.agents/
.claude/skills/
agent/
skills-lock.json

# Yii runtime files
/runtime/*
!/runtime/.gitkeep

# Web assets (generated automatically)
/web/assets/*
!/web/assets/.gitkeep

# Uploaded files (if any)
/web/uploads/*
!/web/uploads/.gitkeep

# Codeception
!/tests/_output/.gitkeep
/.php-cs-fixer.cache
